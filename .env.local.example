# =============================================
# OshiPlan 環境変数テンプレート
# このファイルをコピーして .env.local を作成してください
# =============================================

# --- Supabase ---
# Supabase Dashboard > Settings > API で確認
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Anthropic Claude API ---
# https://console.anthropic.com でAPIキーを発行
ANTHROPIC_API_KEY=sk-ant-...

# --- Google Maps Platform ---
# Google Cloud Console > APIs & Services > Credentials
GOOGLE_MAPS_API_KEY=AIza...

# --- 楽天トラベル API ---
# https://webservice.rakuten.co.jp でアプリ登録
RAKUTEN_APP_ID=your-rakuten-app-id
RAKUTEN_AFFILIATE_ID=your-affiliate-id

# --- Amazon アソシエイト ---
# https://affiliate.amazon.co.jp
AMAZON_ASSOCIATE_TAG=oshiplan-22

# --- じゃらん アフィリエイト ---
# A8.net や Valuecommerce 経由で取得
JALAN_AFFILIATE_ID=your-jalan-affiliate-id

# --- Sentry（エラー監視）---
# https://sentry.io でプロジェクト作成後に取得
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# --- Vercel KV（Redis / レート制限用）---
# Vercel Dashboard > Storage > KV で作成
KV_REST_API_URL=https://...kv.vercel-storage.com
KV_REST_API_TOKEN=your-kv-token

# --- アプリ設定 ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
